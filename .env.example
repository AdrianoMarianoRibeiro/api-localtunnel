APP_HOST=0.0.0.0
APP_PORT=3334

# Tunnel
TUNNEL_ENABLED=true
TUNNEL_PROVIDER=cloudflare
TUNNEL_PROVIDER_FALLBACK=localtunnel
TUNNEL_PORT=3334
TUNNEL_SUBDOMAIN=api-sandbox-confea-local
TUNNEL_HOST=https://localtunnel.me
TUNNEL_STRICT_SUBDOMAIN=true

# cloudflared (quick tunnel by default — no hostname/token needed)
# Set CLOUDFLARED_HOSTNAME for a custom hostname like api-sandbox-confea-local.yourdomain.com
# CLOUDFLARED_HOSTNAME=api-sandbox-confea-local.yourdomain.com
# CLOUDFLARED_TOKEN=your-cloudflare-tunnel-token
# CLOUDFLARED_BINARY=/usr/local/bin/cloudflared
